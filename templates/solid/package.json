{
  "name": "__APP_NAME__",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit && oxlint",
    "test": "playwright test",
    "test:unit": "vitest run",
    "lint": "oxlint --fix",
    "format": "oxfmt --write",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "ad4m:init": "bin/ad4m init",
    "ad4m:start": "bin/ad4m start",
    "ad4m:stop": "bin/ad4m stop",
    "ad4m:restart": "bin/ad4m restart",
    "ad4m:status": "bin/ad4m status",
    "ad4m:logs": "bin/ad4m logs",
    "prepare": "husky"
  },
  "dependencies": {
    "@coasys/ad4m": "link:../ad4m/core",
    "@coasys/ad4m-connect": "link:../ad4m/connect",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^10.3.4",
    "@storybook/blocks": "^8.6.14",
    "@tailwindcss/vite": "^4.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "storybook": "^10.3.4",
    "storybook-solidjs-vite": "^10.0.12",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.{json,css,md,html}": [
      "oxfmt --write"
    ]
  }
}

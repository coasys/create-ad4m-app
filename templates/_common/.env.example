# AD4M executor configuration. Copy to .env and edit.
#
# Backend (read by bin/ad4m):
#   AD4M_CLI_PATH           Absolute path to the ad4m-executor binary.
#                           e.g. /usr/local/bin/ad4m-executor, or a
#                           local checkout's target/release/ad4m-executor.
#   AD4M_DATA_PATH          Per-app data dir. Each app should have its
#                           own — defaults to ~/.ad4m-<app-name>.
#   AD4M_PORT               API port. Default 12000.
#   AD4M_AGENT_PASSPHRASE   Passphrase for the master agent. Required
#                           on first start; cached in the data dir.
#   MULTI_USER              "true" to start with --enable-multi-user.
#
# Frontend (read by Vite — must be prefixed VITE_ to reach the browser):
#   VITE_AD4M_PORT          API port for the browser client.
#   VITE_AD4M_USER_EMAIL    Multi-user login email.
#   VITE_AD4M_USER_PASSWORD Multi-user login password.

AD4M_CLI_PATH=
AD4M_DATA_PATH=
AD4M_PORT=12000
AD4M_AGENT_PASSPHRASE=
MULTI_USER=false

VITE_AD4M_PORT=12000
VITE_AD4M_USER_EMAIL=
VITE_AD4M_USER_PASSWORD=
